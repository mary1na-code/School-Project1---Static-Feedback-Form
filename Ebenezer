<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CSS Box Model</title>

    <style>
        *{
            box-sizing:border-box;
            
        }

        body{
            background: black;
        }

        main{
            width: 90%;
            margin: 42px auto;
            display: flex;
            gap: 12px;
        }
        
        img{
            width: 100%;
            height: 100%;
            object-fit: cover;
            margin: 12px;
        }

        section{
            display: flex;
            flex-direction:column;
            align-items:center;
            width: 1fr;
            height: auto;  
            overflow: hidden;
            padding: 30px;
            background-color: white;
            border: 4px solid green;
        }
    </style>
</head>
<body>
    <main>
        <section>
            <img src="https://cdn.wallpapersafari.com/27/53/YIEmwl.jpg" alt="an image of a mountain view">
        </section>
        <section>
            <img src="https://cdn.pixabay.com/photo/2023/12/15/22/37/mountains-8451480_1280.jpg" alt="a landscape image of a lake with mountains in the background">
        </section>
        <section>
            <img src="https://www.pixelstalk.net/wp-content/uploads/2016/04/Landscape-pictures-images-download.jpg" alt="an image of a sparkling lake water">
        </section>
    </main>
</body>
</html>
